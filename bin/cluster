#!/usr/bin/env python3
"""Cluster session manager — works on both local and cluster machines.

Subcommands:
  status <type>   Check for a live session; print JSON or exit 1
  start <type>    Run ON cluster: submit srun job, write ~/.remotedev/<type>.json
  pty             Run ON cluster: interactive PTY session (reuses by default)
  connect <type>  Run LOCALLY: SSH, start/reuse session, tunnel, open browser
"""

import argparse
import json
import os
import signal
import subprocess
import sys
import time
from pathlib import Path

SESSION_DIR = Path.home() / ".remotedev"
DEFAULTS = dict(cores=32, hours=4, mem="64GB", partition="batch_amd_32c", gres="a40:1")
DEFAULT_PORT = {"jupyter": 8888, "vscode": 8000}


def srun_args(a):
    """Build srun argument list from parsed args."""
    if a.gpu:
        partition = "gpu"
        args = ["-p", partition, "-c", str(a.cores), "-t", f"{a.hours}:00:00", "--mem", a.mem, f"--gres=gpu:{a.gres}"]
    else:
        args = ["-p", a.partition, "-c", str(a.cores), "-t", f"{a.hours}:00:00", "--mem", a.mem]
    return args


def get_session(session_type):
    """Return session dict if a live session exists, else None."""
    f = SESSION_DIR / f"{session_type}.json"
    if not f.exists():
        return None
    session = json.loads(f.read_text())
    job_id = session.get("job_id")
    if job_id:
        r = subprocess.run(
            ["squeue", "-j", str(job_id), "-h"], capture_output=True, text=True
        )
        if not r.stdout.strip():
            f.unlink()
            return None
    return session


def ssh(host, cmd, **kw):
    """Run a command on host via SSH."""
    return subprocess.run(["ssh", host, cmd], **kw)


# ── subcommands ───────────────────────────────────────────────────────────────


def cmd_status(args):
    s = get_session(args.type)
    if not s:
        sys.exit(1)
    print(json.dumps(s))


def cmd_start(args):
    SESSION_DIR.mkdir(exist_ok=True)
    session_file = SESSION_DIR / f"{args.type}.json"
    port = args.port or DEFAULT_PORT[args.type]
    write_json = (
        f'echo \'{{"node":"\'$(hostname)\'","port":{port},'
        f'"job_id":"\'$SLURM_JOB_ID\'","type":"{args.type}"}}\' > {session_file}'
    )

    if args.type == "jupyter":
        inner = (
            f"{write_json}\n"
            f"source ~/envs/jlab/bin/activate && "
            f"jupyter lab --no-browser --port={port} --ip=0.0.0.0 "
            f"--ServerApp.token='' --ServerApp.password=''"
        )
    else:
        inner = (
            f"_log=$(mktemp)\n"
            f'code-cli serve-web --port {port} 2>&1 | tee "$_log" &\n'
            f"_pid=$!\n"
            f"for _i in $(seq 1 30); do\n"
            f"  _token=$(grep -oP '(?<=\\?tkn=)[a-zA-Z0-9-]+' \"$_log\" 2>/dev/null | head -1)\n"
            f'  [ -n "$_token" ] && break\n'
            f"  sleep 1\n"
            f"done\n"
            f'echo \'{{"node":"\'$(hostname)\'","port":{port},'
            f'"job_id":"\'$SLURM_JOB_ID\'","type":"vscode","token":"\'$_token\'"}}\' > {session_file}\n'
            f"wait $_pid"
        )

    subprocess.Popen(
        ["srun"] + srun_args(args) + ["bash", "-c", inner], start_new_session=True
    )


def cmd_pty(args):
    if not args.new:
        s = get_session("pty")
        if s:
            print(
                f"Existing PTY job {s['job_id']} on {s['node']}. SSH: ssh {s['node']}"
            )
            print("Use --new to start a fresh session.")
            return

    SESSION_DIR.mkdir(exist_ok=True)
    session_file = SESSION_DIR / "pty.json"
    inner = (
        f'echo \'{{"node":"\'$(hostname)\'",'
        f'"job_id":"\'$SLURM_JOB_ID\'","type":"pty"}}\' > {session_file}\n'
        f"exec bash"
    )
    os.execvp("srun", ["srun"] + srun_args(args) + ["--pty", "bash", "-c", inner])


def cmd_connect(args):
    host = os.environ.get("CLUSTER_HOST", args.cluster_host)
    port = args.port or DEFAULT_PORT[args.type]
    local_port = args.local_port or port

    if not args.new:
        r = ssh(
            host,
            f"python3 $HOME/bin/cluster status {args.type}",
            capture_output=True,
            text=True,
        )
        if r.returncode == 0:
            s = json.loads(r.stdout.strip())
            print(f"Reusing {args.type} on {s['node']}:{s['port']}")
            _tunnel(
                host, s["node"], s["port"], local_port, s.get("token"), s.get("job_id")
            )
            return

    start_cmd = (
        f"source ~/.bashrc; python3 $HOME/bin/cluster start {args.type} "
        f"--cores {args.cores} --hours {args.hours} --mem {args.mem} --port {port}"
        + (f" --gpu --gres {args.gres}" if args.gpu else "")
    )
    subprocess.Popen(["ssh", host, start_cmd])

    print(f"Waiting for {args.type} to start", end="", flush=True)
    for _ in range(60):
        time.sleep(2)
        r = ssh(
            host,
            f"python3 $HOME/bin/cluster status {args.type}",
            capture_output=True,
            text=True,
        )
        if r.returncode == 0:
            s = json.loads(r.stdout.strip())
            print(f"\n{args.type} on {s['node']}:{s['port']}")
            _tunnel(
                host, s["node"], s["port"], local_port, s.get("token"), s.get("job_id")
            )
            return
        print(".", end="", flush=True)

    print("\nTimed out. Check the cluster.")
    sys.exit(1)


def _tunnel(host, node, remote_port, local_port, token=None, job_id=None):
    tunnel = subprocess.Popen(
        ["ssh", "-N", "-L", f"{local_port}:localhost:{remote_port}", "-J", host, node]
    )
    print(f"Tunnel: localhost:{local_port} → {node}:{remote_port}  (PID {tunnel.pid})")
    time.sleep(1)
    url = f"http://localhost:{local_port}" + (f"?tkn={token}" if token else "")
    subprocess.Popen(
        ["open", "-a", "Google Chrome", url],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
    try:
        tunnel.wait()
    except KeyboardInterrupt:
        tunnel.terminate()
        if job_id:
            print(f"\nCancelling job {job_id}...")
            signal.signal(signal.SIGINT, signal.SIG_IGN)
            subprocess.run(["ssh", host, f"scancel {job_id}"])


# ── arg parsing ───────────────────────────────────────────────────────────────


def add_srun_args(p):
    p.add_argument("--cores", type=int, default=DEFAULTS["cores"])
    p.add_argument("--hours", type=int, default=DEFAULTS["hours"])
    p.add_argument("--mem", default=DEFAULTS["mem"])
    p.add_argument("--partition", default=DEFAULTS["partition"])
    p.add_argument("--gpu", action="store_true")
    p.add_argument("--gres", default=DEFAULTS["gres"])


def main():
    parser = argparse.ArgumentParser(description="Cluster session manager")
    sub = parser.add_subparsers(dest="cmd", required=True)

    p = sub.add_parser("status")
    p.add_argument("type", choices=["jupyter", "vscode", "pty"])

    p = sub.add_parser("start")
    p.add_argument("type", choices=["jupyter", "vscode"])
    p.add_argument("--port", type=int)
    add_srun_args(p)

    p = sub.add_parser("pty")
    p.add_argument("--new", action="store_true")
    add_srun_args(p)

    p = sub.add_parser("connect")
    p.add_argument("type", choices=["jupyter", "vscode"])
    p.add_argument("--port", type=int)
    p.add_argument("--local-port", dest="local_port", type=int)
    p.add_argument("--cluster-host", dest="cluster_host", default="lam")
    p.add_argument("--new", action="store_true")
    add_srun_args(p)

    args = parser.parse_args()
    {"status": cmd_status, "start": cmd_start, "pty": cmd_pty, "connect": cmd_connect}[
        args.cmd
    ](args)


if __name__ == "__main__":
    main()
